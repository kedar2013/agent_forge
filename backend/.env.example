# --- Database ---
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/dbname
DB_SCHEMA=agent_forge

# --- LLM (agent layer) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Optional. Only required if you select one of the "Claude (Anthropic)"
# options in the Agent Builder's Model dropdown for at least one agent —
# routed through ADK's LiteLlm adapter (model stored as "anthropic/<id>").
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# --- Generic MySQL Database ---
# Discovered generically by config_api/data_entities.py's connection scan —
# any data_query_tool/mysql_query_tool whose connection_env_prefix is
# "MYSQL" reads this block. Can be the same physical MySQL server as every
# other *_MYSQL_*/SALES_DB_* block below, just a different database name.
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=agentic_ai

# --- Sales Analytics MySQL Database (slide_reporting_agent) ---
# A separate MySQL database (its own schema.sql — regions/sales_reps/
# categories/products/customers/orders/order_items/sales_targets), used only
# by mcp_servers/slide_reporting_server.py. Can be the same MySQL server as
# any other MYSQL_* config elsewhere, just a different database name.
SALES_DB_HOST=localhost
SALES_DB_PORT=3306
SALES_DB_USER=root
SALES_DB_PASSWORD=
SALES_DB_NAME=sales_analytics

# --- Credit Facility Analysis (MySQL) ---
# Domain data (companies, personas, coverage, monthly facility numbers) for
# backend/app/domains/credit_facility/ — a worked example of a MySQL-backed,
# identity-scoped domain on top of the generic mysql_query_tool +
# access_policies row-level-security framework. Can be the same MySQL server
# as any other MYSQL_*/SALES_DB_* config elsewhere — tables are prefixed
# cf_ to avoid collisions. Seed with (from backend/):
#   python -m app.domains.credit_facility.seed_data
#   python -m app.domains.credit_facility.seed_agent
CREDIT_FACILITY_MYSQL_HOST=localhost
CREDIT_FACILITY_MYSQL_PORT=3306
CREDIT_FACILITY_MYSQL_USER=root
CREDIT_FACILITY_MYSQL_PASSWORD=
CREDIT_FACILITY_MYSQL_DATABASE=agentic_ai

# --- Revenue and Returns Analysis (MySQL) ---
# Domain data (products, revenue, returns) for
# backend/app/domains/revenue_and_returns/ — same generic MySQL-backed
# pattern as Credit Facility Analysis above. Can be the same MySQL server as
# every other *_MYSQL_*/SALES_DB_* block here — tables are prefixed rr_ to
# avoid collisions. Seed with (from backend/):
#   python -m app.domains.revenue_and_returns.seed_data
#   python -m app.domains.revenue_and_returns.seed_agent
REVENUE_RETURNS_MYSQL_HOST=localhost
REVENUE_RETURNS_MYSQL_PORT=3306
REVENUE_RETURNS_MYSQL_USER=root
REVENUE_RETURNS_MYSQL_PASSWORD=
REVENUE_RETURNS_MYSQL_DATABASE=agentic_ai

# Absolute base URL the backend is reachable at, for download links returned
# by export-style mcp_servers/*.py tools (document_export_server.py,
# slide_reporting_server.py). Falls back to http://127.0.0.1:8000 if unset —
# 8000 is this project's one canonical local-dev backend port (see
# docker-entrypoint.sh's $PORT default and frontend/.env.example).
BACKEND_PUBLIC_URL=http://127.0.0.1:8000

# --- Embeddings (for retrieval_tool) ---
EMBEDDING_PROVIDER=local
EMBEDDING_DIM=384

# --- Admin API auth ---
# Single static bearer token for this backend-only phase. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Below 32 chars, app/config.py refuses to boot once ENV != development —
# see the ENV note below.
AGENT_FORGE_API_TOKEN=changeme

# --- End-user chat auth ---
# Signs the per-user chat tokens issued at /api/auth/login, once approved,
# and the signed download links generated_files_auth.py issues for
# generated-files/generated-images. Same 32-char minimum as above once
# ENV != development.
USER_TOKEN_SECRET=changeme

# --- App ---
# "development" is intentionally permissive (no secret-strength or
# CORS_ORIGINS checks) so a fresh local checkout always boots. Set this to
# anything else ("staging", "production", ...) on a real deployment and
# app/config.py's Settings validator enforces the rest: a real
# USER_TOKEN_SECRET/AGENT_FORGE_API_TOKEN (not the placeholders above, >= 32
# chars) and a CORS_ORIGINS with no localhost/127.0.0.1 entries — the app
# refuses to start otherwise rather than silently serving with a dev-grade
# config.
ENV=development

# --- Debug Console / distributed tracing (optional) ---
# Off by default. Flip on once a trace backend is reachable — e.g. run
# `docker compose up -d jaeger` (repo root) for a local one-command Jaeger.
OTEL_ENABLED=false
OTEL_SERVICE_NAME=agent-forge-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
JAEGER_QUERY_URL=http://localhost:16686
